# ============================================
# ServiceFlow - Environment Configuration
# ============================================

# ============================================
# Database (PostgreSQL)
# ============================================
POSTGRES_USER=serviceflow
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=serviceflow

# ============================================
# JWT Authentication
# ============================================
# IMPORTANT: Change this in production!
JWT_SECRET=your_secure_jwt_secret_min_32_chars

# ============================================
# CORS - Allowed Origins
# ============================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4200,https://yourdomain.com

# ============================================
# Application URLs
# ============================================
FRONTEND_URL=http://localhost
NODE_ENV=development

# ============================================
# Security (Rate Limiting)
# ============================================
# Already configured in code:
# - Global: 100 requests/minute
# - Login: 5 attempts/minute
# - Register: 3 attempts/minute

# ============================================
# SMTP Email Configuration
# ============================================
# Enable/disable email notifications
SMTP_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_email_password
SMTP_FROM=noreply@serviceflow.local

# ============================================
# LDAP Configuration
# ============================================
# Enable/disable LDAP authentication
LDAP_ENABLED=false
LDAP_URL=ldap://ldap.example.com:389
LDAP_BIND_DN=cn=service,dc=example,dc=com
LDAP_BIND_PASSWORD=ldap_bind_password
LDAP_SEARCH_BASE=ou=users,dc=example,dc=com
LDAP_SEARCH_FILTER=(uid={{username}})

# ============================================
# SSO Configuration (Future)
# ============================================
# SSO_ENABLED=false
# SSO_PROVIDER=okta|azure|saml
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_ISSUER_URL=

# ============================================
# File Storage
# ============================================
UPLOAD_DIR=/tmp/uploads
MAX_FILE_SIZE=10485760

# ============================================
# Session Configuration
# ============================================
SESSION_TIMEOUT=86400

# ============================================
# Production Notes:
# ============================================
# 1. Always change JWT_SECRET to a secure random string
# 2. Use strong PostgreSQL password
# 3. Configure SMTP for email notifications
# 4. Set up SSL/TLS in production (reverse proxy)
# 5. Consider using Docker secrets for sensitive data
# 6. Set ALLOWED_ORIGINS to your domain in production
# 7. Configure LDAP for enterprise authentication
