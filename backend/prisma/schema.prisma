// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Run seed: npx prisma db seed
// Or: npm run db:seed

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// RBAC Models (OpenProject-style)
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique  // e.g., "Admin", "Manager", "User"
  description String?
  type        String   @default("PROJECT")  // GLOBAL, PROJECT, ENTITY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  members     Member[]
  users       User[]   // Users with this as global role

  @@index([type])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique  // e.g., "forms.create", "workflows.delete", "users.manage"
  description String?
  module      String   // e.g., "forms", "workflows", "users", "admin"
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@index([module])
}

// Lookup table: Role <-> Permission (many-to-many)
model RolePermission {
  id            String   @id @default(uuid())
  roleId        String
  permissionId  String
  createdAt     DateTime @default(now())

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Member: User + Role + Scope (who has what role where)
// Scope types:
//   - GLOBAL: user has role system-wide
//   - PROJECT: user has role for a specific project (workflow/form)
//   - ENTITY: user has role for a specific entity instance
model Member {
  id          String   @id @default(uuid())
  userId      String
  roleId      String
  scopeType   String   @default("GLOBAL")  // GLOBAL, PROJECT, ENTITY
  scopeId     String?  // workflow/form ID if PROJECT or ENTITY scope
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Optional relations for scoping
  form        Form?    @relation(fields: [scopeId], references: [id])
  workflow    Workflow? @relation(fields: [scopeId], references: [id])

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
}

// ============================================
// Application Models
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String    // Empty string for LDAP users
  name          String
  department    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Legacy: keep role for simple checks (e.g., seed data)
  role          String    @default("USER")  // ADMIN, MANAGER, USER
  source        String    @default("LOCAL") // LOCAL, LDAP, SAML
  globalRoleId  String?   // FK to Role for global admin
  globalRole    Role?     @relation(fields: [globalRoleId], references: [id])

  formSubmissions   FormSubmission[]
  forms            Form[]
  workflows        Workflow[]
  approvalRequests ApprovalRequest[]  @relation("ApprovalOriginalApprover")
  approvalsGivenAsActual ApprovalRequest[] @relation("ApprovalActualApprover")
  workflowInstances WorkflowInstance[]
  notifications    Notification[]
  members          Member[]
  delegations       Delegation[]  @relation("Delegator")
  delegatedTo      Delegation[]  @relation("Delegate")
}

model Form {
  id          String   @id @default(uuid())
  name        String
  description String?
  elements    String   // JSON string for FormElement[]
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  submissions FormSubmission[]
  members     Member[]  // Project-scoped permissions
  versions    FormVersion[] // Version history

  @@index([userId])
}

model FormVersion {
  id         String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  version   Int
  elements  String   // JSON snapshot
  name      String
  createdAt DateTime @default(now())
  createdBy String

  @@unique([formId, version])
  @@index([formId])
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  data      String   // JSON string for submitted form data
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  nodes       String   // JSON string for WorkflowNode[]
  connections String   // JSON string for WorkflowConnection[]
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  instances   WorkflowInstance[]
  members     Member[]  // Project-scoped permissions
  escalationRules EscalationRule[]

  @@index([userId])
}

model WorkflowInstance {
  id               String   @id @default(uuid())
  workflowId       String
  workflow         Workflow @relation(fields: [workflowId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  currentNodeId    String?
  status           String   @default("PENDING")
  formData         String   @default("{}")
  history          String   @default("[]")
  childInstanceId  String?
  parentInstanceId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  approvalRequests ApprovalRequest[]
}

model ApprovalRequest {
  id          String   @id @default(uuid())
  instanceId  String
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id])
  nodeId      String
  userId      String   // Original approver
  user        User     @relation("ApprovalOriginalApprover", fields: [userId], references: [id])
  actualApproverId String? // Who actually approved (original or delegate)
  actualApprover User? @relation("ApprovalActualApprover", fields: [actualApproverId], references: [id])
  decision    String?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Delegation {
  id           String   @id @default(uuid())
  delegatorId  String   // Original approver
  delegateId   String   // Person who can approve on behalf
  reason       String?  // e.g., "Vacation", "Out of office"
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  
  delegator    User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegate     User     @relation("Delegate", fields: [delegateId], references: [id])
  
  @@index([delegatorId])
  @@index([delegateId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EscalationRule {
  id              String   @id @default(uuid())
  workflowId       String?
  workflow        Workflow? @relation(fields: [workflowId], references: [id])
  nodeType        String   // approval, form, task
  timeoutMinutes  Int      // Minutes before escalation
  level1ApproverId String?
  level2ApproverId String?
  level3ApproverId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([workflowId])
}

model EscalationLog {
  id                String   @id @default(uuid())
  instanceId        String
  approvalRequestId String
  level             Int      // 0 = original, 1 = first escalation, etc.
  escalatedAt       DateTime @default(now())
  reason            String   // e.g., "Timeout after 24 hours"
  previousApproverId String?
  newApproverId     String?
}

model FormTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  elements    String   // JSON array of form elements
  category    String   @default("general") // leave, expense, it, hr, general
  isBuiltIn   Boolean  @default(false)
  userId      String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([userId])
}
