// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Run seed: npx prisma db seed
// Or: npm run db:seed

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// RBAC Models (OpenProject-style)
// ============================================

model Role {
  id          String   @id @default(uuid())
  name        String   @unique  // e.g., "Admin", "Manager", "User"
  description String?
  type        String   @default("PROJECT")  // GLOBAL, PROJECT, ENTITY
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  members     Member[]
  users       User[]   // Users with this as global role

  @@index([type])
}

model Permission {
  id          String   @id @default(uuid())
  name        String   @unique  // e.g., "forms.create", "workflows.delete", "users.manage"
  description String?
  module      String   // e.g., "forms", "workflows", "users", "admin"
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@index([module])
}

// Lookup table: Role <-> Permission (many-to-many)
model RolePermission {
  id            String   @id @default(uuid())
  roleId        String
  permissionId  String
  createdAt     DateTime @default(now())

  role          Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Member: User + Role + Scope (who has what role where)
// Scope types:
//   - GLOBAL: user has role system-wide
//   - PROJECT: user has role for a specific project (workflow/form)
//   - ENTITY: user has role for a specific entity instance
model Member {
  id          String   @id @default(uuid())
  userId      String
  roleId      String
  scopeType   String   @default("GLOBAL")  // GLOBAL, PROJECT, ENTITY
  scopeId     String?  // workflow/form ID if PROJECT or ENTITY scope
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  // Optional relations for scoping
  form        Form?    @relation(fields: [scopeId], references: [id])
  workflow    Workflow? @relation(fields: [scopeId], references: [id])

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@index([roleId])
  @@index([scopeType, scopeId])
}

// ============================================
// Application Models
// ============================================

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  department    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Legacy: keep role for simple checks (e.g., seed data)
  role          String    @default("USER")  // ADMIN, MANAGER, USER
  globalRoleId  String?   // FK to Role for global admin
  globalRole    Role?     @relation(fields: [globalRoleId], references: [id])

  formSubmissions   FormSubmission[]
  forms            Form[]
  workflows        Workflow[]
  approvalRequests ApprovalRequest[]
  workflowInstances WorkflowInstance[]
  notifications    Notification[]
  members          Member[]
}

model Form {
  id          String   @id @default(uuid())
  name        String
  description String?
  elements    String   // JSON string for FormElement[]
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  submissions FormSubmission[]
  members     Member[]  // Project-scoped permissions

  @@index([userId])
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  form      Form     @relation(fields: [formId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  data      String   // JSON string for submitted form data
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Workflow {
  id          String   @id @default(uuid())
  name        String
  description String?
  nodes       String   // JSON string for WorkflowNode[]
  connections String   // JSON string for WorkflowConnection[]
  version     Int      @default(1)
  isActive    Boolean  @default(true)
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String
  user        User     @relation(fields: [userId], references: [id])

  instances   WorkflowInstance[]
  members     Member[]  // Project-scoped permissions

  @@index([userId])
}

model WorkflowInstance {
  id               String   @id @default(uuid())
  workflowId       String
  workflow         Workflow @relation(fields: [workflowId], references: [id])
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  currentNodeId    String?
  status           String   @default("PENDING")
  formData         String   @default("{}")
  history          String   @default("[]")
  childInstanceId  String?
  parentInstanceId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  approvalRequests ApprovalRequest[]
}

model ApprovalRequest {
  id          String   @id @default(uuid())
  instanceId  String
  instance    WorkflowInstance @relation(fields: [instanceId], references: [id])
  nodeId      String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  decision    String?
  comment     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String
  title     String
  message   String
  data      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
